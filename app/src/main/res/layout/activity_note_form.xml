<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/layoutNoteCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_note_form">

        <EditText
            android:id="@+id/editTextTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titre"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCFFFFFF"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:maxLines="2"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/editTextContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:hint="Contenu de la note..."
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCFFFFFF"
            android:background="@android:color/transparent"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:padding="4dp" />

    </LinearLayout>

    <!-- PALETTE DE COULEURS AJOUTÉE ICI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="#FFFFFF">

        <View
            android:id="@+id/circle_green"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_green"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/circle_red"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_red"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/circle_blue"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_blue"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/circle_yellow"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_yellow"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/circle_orange"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_orange"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:id="@+id/circle_grey"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="6dp"
            android:background="@drawable/circle_grey"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Créer"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/btn_save"
        android:stateListAnimator="@null" />

</LinearLayout>

